# Copy this file to .env and fill in real values

# Postgres — matches docker-compose service
DATABASE_URL=postgresql+asyncpg://agrisync:agrisync@db:5432/agrisync

# Set to false on AMD MI300X node to use real model inference
USE_MOCK_VISION=true

# Vision model — "llama32" (Track 3 primary, ROCm-optimised) or "llava" (domain-finetuned fallback)
VISION_MODEL=llama32

# HuggingFace model IDs
LLAMA32_MODEL_ID=meta-llama/Llama-3.2-11B-Vision-Instruct
LLAVA_MODEL_ID=YuchengShi/LLaVA-v1.5-7B-Plant-Leaf-Diseases-Detection
MISTRAL_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2

# HuggingFace token — required for gated models (Llama 3.2); get from hf.co/settings/tokens
HUGGINGFACE_TOKEN=

# Africa's Talking SMS API (optional)
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox

# ROCm GPU selection (AMD MI300X)
ROCM_VISIBLE_DEVICES=0

# Disable CrewAI telemetry (avoids 30s timeout in environments without internet)
CREWAI_TELEMETRY_OPT_OUT=true
OTEL_SDK_DISABLED=true

# Security — set a strong random value in production; empty = auth disabled (dev/demo)
API_KEY=

# CORS — comma-separated allowed origins; "*" = all origins (dev/demo only)
# Production example: FRONTEND_URL=https://agrisync.example.com
FRONTEND_URL=*
