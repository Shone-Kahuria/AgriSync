# Copy this file to .env and fill in real values

# Postgres — matches docker-compose service
DATABASE_URL=postgresql+asyncpg://agrisync:agrisync@db:5432/agrisync

# Set to false on AMD MI300X node to use real LLaVA + Mistral inference
USE_MOCK_VISION=true

# HuggingFace model IDs (change only if you fork the models)
LLAVA_MODEL_ID=YuchengShi/LLaVA-v1.5-7B-Plant-Leaf-Diseases-Detection
MISTRAL_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2

# Africa's Talking SMS API (optional)
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox

# ROCm GPU selection (AMD MI300X)
ROCM_VISIBLE_DEVICES=0

# Disable CrewAI telemetry (avoids 30s timeout in environments without internet)
CREWAI_TELEMETRY_OPT_OUT=true
OTEL_SDK_DISABLED=true
